<?xml version="1.0" encoding="utf-8"?>
<!-- Inflation Card Layout - Modern metric card with visual comparison -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardInflation"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Metric Title Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">

            <!-- Icon Container -->
            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_icon_teal">
                
                <ImageView
                    android:id="@+id/imgMetricIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_inflasi"
                    app:tint="@android:color/white" />
            </FrameLayout>

            <!-- Metric Name -->
            <TextView
                android:id="@+id/txtMetricName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Month to Month"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginBottom="16dp"
            android:background="@color/dividerColor" />

        <!-- Values Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Jateng Value Box -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardJateng"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bgJateng"
                app:strokeWidth="1dp"
                app:strokeColor="@color/borderJateng">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JATENG"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/textJatengLabel"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/txtJatengValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0.50"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/textJatengValue" />

                    <!-- Progress Bar -->
                    <ProgressBar
                        android:id="@+id/progressJateng"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progress="50"
                        android:progressDrawable="@drawable/progress_jateng" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Nasional Value Box -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNasional"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bgNasional"
                app:strokeWidth="1dp"
                app:strokeColor="@color/borderNasional">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NASIONAL"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/textNasionalLabel"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/txtNasionalValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0.64"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/textNasionalValue" />

                    <!-- Progress Bar -->
                    <ProgressBar
                        android:id="@+id/progressNasional"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progress="64"
                        android:progressDrawable="@drawable/progress_nasional" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
