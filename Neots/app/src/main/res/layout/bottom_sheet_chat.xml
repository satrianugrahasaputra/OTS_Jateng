<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/main_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/primaryColor"
        android:gravity="center_vertical">

        <!-- Profile Photo -->
        <ImageView
            android:id="@+id/imgLatifaProfile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/latifa"
            android:contentDescription="LATIFA Profile"
            android:background="@drawable/circle_background"
            android:padding="4dp" />

        <!-- Name and Status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/txtLatifaName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LATIFA (Asisten Statistik)"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/online_indicator" />

                <TextView
                    android:id="@+id/txtLatifaStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Online"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Close Button -->
        <ImageButton
            android:id="@+id/btnCloseChat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close Chat"
            app:tint="@android:color/white" />
    </LinearLayout>

    <!-- Chat Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- Input Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/card_background"
        android:elevation="4dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etChatInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Ketik pesan..."
            android:padding="12dp"
            android:background="@drawable/chat_input_background"
            android:maxLines="4"
            android:inputType="textMultiLine"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/btnSendMessage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="@drawable/send_button_background"
            android:contentDescription="Send Message"
            app:tint="@android:color/white" />
    </LinearLayout>

</LinearLayout>
